# =============================================
# AI Mate 环境变量配置
# 复制为 .env 后填写：cp .env.example .env
# =============================================

# ── 云端 LLM 模型 ──
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash

# ── 云端模型费用（元 / 百万 tokens） ──
CLOUD_PRICE_IN=1.0
CLOUD_PRICE_OUT=4.0
PRICE_CACHE_IN=0.1

# ── 本地小模型（可选） ──
LOCAL_MODEL_ENABLED=false
LOCAL_MODEL=qwen3-4b
LOCAL_API_BASE=http://127.0.0.1:1234/v1

# ── 飞书 Bot（可选） ──
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=
FEISHU_ENABLED=false

# ── 服务器 ──
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
